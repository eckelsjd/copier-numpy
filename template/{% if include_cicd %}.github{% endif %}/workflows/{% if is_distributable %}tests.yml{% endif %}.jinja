name: Lint and test
on:
  pull_request:
    branches: [ main ]
permissions:
  contents: write
jobs:
  check-lint:
    name: Lint check
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      {% if python_manager == 'pdm' %}- uses: pdm-project/setup-pdm@v4
        with:
          cache: true{% endif -%}
      {%- if python_manager == 'uv' %}- uses: astral-sh/setup-uv@v7
        with:
          version: "0.10.8"
          enable-cache: true
      - run: uv python install{% endif %}
      - run: {{ python_manager }} sync --group dev
      - run: {{ python_manager }} run dev.py lint

  pr-tests:
    name: PR tests
    runs-on: {% raw %}${{ matrix.os }}{% endraw %}
    needs: check-lint
    strategy:
      matrix:
        python-version: ['3.11', '3.12']
        os: [ ubuntu-latest, windows-latest ]
    steps:
      - uses: actions/checkout@v4
      {% if python_manager == 'pdm' %}- uses: pdm-project/setup-pdm@v4
        with:
          cache: true
          python-version: {% raw %}${{ matrix.python-version }}{% endraw %}{% endif -%}
      {%- if python_manager == 'uv' %}- uses: astral-sh/setup-uv@v7
        with:
          version: "0.10.8"
          enable-cache: true
          python-version: {% raw %}${{ matrix.python-version }}{% endraw %}
      - run: uv python install{% endif %}
      - name: Install dependencies
        run: {{ python_manager }} sync --group test
      - name: Run tests
        run: {{ python_manager }} run dev.py test
